# ─────────────────────────────────────────────────────────────
# BINANCE_API
BINANCE_API_KEY=your_binance_futures_api_key_here
BINANCE_API_SECRET=your_binance_futures_api_secret_here
BINANCE_TESTNET=false  # set true for paper trading

# ─────────────────────────────────────────────────────────────
# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────────
# AI / LLM
OPENAI_API_KEY=sk-your_openai_key_here
# Uncomment to use Anthropic Claude instead:
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
LLM_MODEL=gpt-4o  # or claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────────────────────
# TELEGRAM
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─────────────────────────────────────────────────────────────
# SERVICE URLS (inter-service communication)
PYTHON_AI_URL=http://localhost:8000       # Python FastAPI
RUST_CORE_URL=http://localhost:3001       # Rust core API
NEXT_PUBLIC_API_URL=http://localhost:3001 # Web dashboard → backend

# ─────────────────────────────────────────────────────────────
# TRADING CONFIG
MAX_CONCURRENT_POSITIONS=3
MAX_DAILY_LOSS_PCT=3.0
MAX_EQUITY_PER_TRADE_PCT=10.0
MAX_LEVERAGE=10
AI_CONFIDENCE_THRESHOLD=60
CIRCUIT_BREAKER_ENABLED=true

# ─────────────────────────────────────────────────────────────
# RUNTIME
RUST_LOG=info
LOG_LEVEL=info
ENVIRONMENT=development  # development | staging | production
